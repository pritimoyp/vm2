# VM IPs
# VM1 (infra): runs MySQL + MinIO — use same IP for DB_VM_IP and MINIO_VM_IP
# VM2 (app):   runs all application services
DB_VM_IP=192.168.1.x
APPLICATION_VM_IP=192.168.1.y
MINIO_VM_IP=192.168.1.x

# Docker images
USER_IMAGE=polygontechxyz/cyberwise-user:production-1.0.0
LMS_IMAGE=polygontechxyz/cyberwise-lms:production-1.0.0
WEB_IMAGE=polygontechxyz/cyberwise-web:production-1.0.0
GOPHISH_IMAGE=polygontechxyz/cyberwise-gophish:production-1.0.0

# Docker Hub (optional, for private images)
DOCKER_HUB_USER=
DOCKER_HUB_PASS=

# MySQL (VM1 — infra VM)
MYSQL_HOST=192.168.1.x
MYSQL_PORT=3306
MYSQL_USER=cyberwise
MYSQL_PASSWORD=change_me_app
SPRING_DATASOURCE_USERNAME=cyberwise
SPRING_DATASOURCE_PASSWORD=change_me_app

# MinIO (VM1 — infra VM)
MINIO_URL=http://192.168.1.x:9000
MINIO_PUBLIC_URL=http://192.168.1.x:9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=cyberwise

# Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_64_char_hex
APP_SECRET=replace_with_64_char_hex

# JWT expiration times (in milliseconds)
JWT_ACCESS_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
INVITATION_EXPIRATION=86400000
RESET_PASSWORD_EXPIRATION=3600000

# Super admin
SUPER_ADMIN_EMAIL=sadmin@polygon.xyz
SUPER_ADMIN_PASSWORD=Sadmin1234

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER_NAME=your_email@gmail.com
MAIL_PASSWORD=your_smtp_password

DATABASE_HOST_LMS=jdbc:mysql://192.168.1.x:3306/cyberwise_lms?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USER=change_me
DATABASE_PASSWORD=change_me
DATABASE_HOST=jdbc:mysql://192.168.1.x:3306/cyberwise_user?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# gRPC (user → lms)
GRPC_SERVER_HOST=192.168.1.y
GRPC_SERVER_PORT=9090
GRPC_LMS_END_POINT=static://192.168.1.y:10082
GO_PHISH_URL=http://192.168.1.y:3331/api
GO_PHISH_TOKEN=replace_after_gophish_starts
GOPHISH_WEBHOOK_SECRET=replace_with_64_char_hex

# Spring datasource — user service
USER_DATASOURCE_URL=jdbc:mysql://192.168.1.x:3306/cyberwise_user?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Spring datasource — lms service
LMS_DATASOURCE_URL=jdbc:mysql://192.168.1.x:3306/cyberwise_lms?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Gophish
GOPHISH_ADMIN_PORT=3333
GOPHISH_PHISH_PORT=8080

# SQL log level
SQL_LOG_LEVEL=INFO
LOG_LEVEL=INFO

NEXT_PUBLIC_LANDING_PAGE_URL=http://192.168.1.y:8050
LOCAL_URL=http://192.168.1.y:10081/api/v1
API_URL=http://192.168.1.y:10081/api/v1

LICENSE_SECRET=replace_with_license_secret

MAIL_REGISTRATION_URL=http://192.168.1.y:3000/register?x=
MAIL_FORGET_PASSWORD_URL=http://192.168.1.y:3000/auth/confirm-password?x=
MAIL_LOGIN_URL=http://192.168.1.y:3000/login
